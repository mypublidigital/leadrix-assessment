# =============================================================
# Leadrix Assessment — Variáveis de Ambiente
# =============================================================
#
# INSTRUÇÕES DE SETUP
# -------------------
# 1. Copie este arquivo para .env.local (nunca commite .env.local)
# 2. Preencha os valores abaixo com as credenciais do seu projeto Supabase
# 3. Na Vercel, configure as mesmas variáveis em:
#    Project Settings → Environment Variables
#    (defina para Production, Preview e Development)
#
# ONDE ENCONTRAR ESTAS CHAVES
# ----------------------------
# Acesse: https://supabase.com/dashboard → Seu Projeto → Settings → API
# - Project URL          → NEXT_PUBLIC_SUPABASE_URL
# - anon / public key    → NEXT_PUBLIC_SUPABASE_ANON_KEY
# - service_role key     → SUPABASE_SERVICE_ROLE_KEY  (nunca exponha no frontend!)
#
# =============================================================

# URL do projeto Supabase (pública — pode estar no frontend)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima do Supabase (pública — usada no browser e no server)
# Protegida pelas Row Level Security policies do banco
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de service role — APENAS no servidor (Server Actions, Route Handlers)
# NUNCA use no frontend / Client Components
# Usada para operações administrativas que precisam contornar RLS
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL pública do app (usada em redirects de auth e e-mails)
# Local:      http://localhost:3000
# Produção:   https://leadrix-assessment.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================
# CONFIGURAÇÕES SUPABASE AUTH (configurar no painel Supabase)
# =============================================================
#
# Em: Authentication → URL Configuration
#
# Site URL:
#   https://leadrix-assessment.vercel.app
#
# Redirect URLs (adicionar todos):
#   http://localhost:3000/auth/callback
#   https://leadrix-assessment.vercel.app/auth/callback
#   https://*.vercel.app/auth/callback  ← para preview deploys
#
# =============================================================
